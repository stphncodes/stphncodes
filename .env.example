# Contact form — Web3Forms (https://web3forms.com)
# Create a free access key at https://web3forms.com/ using stphncodes@gmail.com.
# This key is public-safe (used client-side); restrict it to your domain in the
# Web3Forms dashboard. Copy this file to .env.local and fill in the value.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here

# Google Search Console — site ownership verification.
# Add a "URL prefix" property for https://www.cloudwithstephen.com, choose the
# "HTML tag" method, and copy ONLY the content="..." token (not the full tag).
# Set this in Vercel (Project → Settings → Environment Variables) and redeploy.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token-here

# Anthropic API — powers the floating chat widget (server-side only).
# Create a key at https://console.anthropic.com/settings/keys
# NOTE: no NEXT_PUBLIC_ prefix — this must never reach the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here
